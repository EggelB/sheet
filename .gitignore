# ============================================================
# .gitignore — Enemies in the Shadows TTRPG Codebase
# ============================================================
# Organized by category. Keep alphabetical within sections.

# --- OS artifacts ---
.DS_Store
Thumbs.db

# --- Editor / IDE ---
.vscode/

# --- Python ---
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
dist/
build/
*.egg-info/
*.egg

# --- Node / SvelteKit (companion app) ---
node_modules/
.svelte-kit/
.wrangler/

# --- Companion app local secrets ---
companion/.dev.vars

# --- TEMPO runtime state (machine-specific, regenerated each session) ---
.github/workflow-state.json

# --- Elements: reference materials (local-only) ---
# Obsidian source .md files from the GM — used for comparison, not code
elements/*/
# Excel workbooks and image references
elements/*.xlsx
elements/*.png
# Excel temp files
~$*.xlsx

# --- Local scripts & one-off files ---
verify*.py
tempo_gate.ps1
sheet_backup.html

# --- Logs ---
*.log
