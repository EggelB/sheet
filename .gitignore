# Virtual environment
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Test & coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Linter / type checker caches
.ruff_cache/
.mypy_cache/

# Logs
*.log

# TEMPO runtime state — machine-specific, regenerated each session
.github/workflow-state.json

# OS artifacts
.DS_Store
Thumbs.db

# Editor config
.vscode/

# Archive — old prototypes, not needed in repo
archive/

# One-off verification scripts
verify*.py

# Manual backup files
sheet_backup.html

# Local gate script
tempo_gate.ps1

# Binary reference files — source of truth lives locally
plans/*.xlsx
plans/*.png

# Excel temp files
~$*.xlsx
